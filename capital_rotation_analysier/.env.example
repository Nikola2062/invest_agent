# ============================================================
# Capital Rotation Monitoring System — credentials template
# ============================================================
# Copy this file to `.env` (which is .gitignored) and fill in real values.
# Then before running: `set -a; source .env; set +a`  (or use a tool like direnv).
#
# Empty / unset variables: the related feature is *disabled silently*. No errors,
# no crashes — just the relevant signal/alert/data source is skipped and the
# system continues. This is the documented behaviour in §4.5 anti-hallucination.
# ============================================================


# ---------- Telegram (alerts + daily heartbeat) ----------
# How to obtain:
#   1. Open Telegram, search for "@BotFather", message it `/newbot`.
#   2. Follow the prompts; it gives you a token like the example below.
#   3. Send any message to your new bot, then visit
#      https://api.telegram.org/bot<TOKEN>/getUpdates  and read off your chat id
#      from the `chat.id` field of the most recent update.
#
# Without these two, no Telegram alert fires; file-sink alerts still write to ./alerts/.
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxyz_FAKE_REPLACE_ME
TELEGRAM_CHAT_ID=123456789


# ---------- (Email/SMTP intentionally removed) ----------
# Email channel was dropped 2026-06-07 — Gmail SMTP requires an app password
# which the account in use can't generate. Telegram + file sink is the
# operational channel set. If you ever want a second push channel, the
# alerts.py dispatcher takes ~30 lines to add a Discord/Resend hook.


# ---------- DeepSeek LLM (Section 12 narrative generation) ----------
# How to obtain:
#   Visit https://platform.deepseek.com  → sign up → API Keys → create key.
#   Account credit is paid (cheap: V3 is ~$0.27 / $1.10 per 1M input/output tokens).
#   Daily cost at ~3k input + 1k output per report is < $0.01 / month.
#
# When this key is set, Section 12 of the daily report is generated by the LLM
# (currently `deepseek-chat` = V3). When unset, Section 12 falls back to the
# deterministic rule-based narrative library. The §4.5 hedge-language and
# anti-hallucination rules are enforced in the prompt regardless of which path.
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ---------- FRED (Federal Reserve Economic Data — RRP for Liquidity score) ----------
# How to obtain:
#   Visit https://fred.stlouisfed.org/docs/api/api_key.html  and create a free
#   account. Key generation is instant. No rate-limit issues at our cadence
#   (~10 calls per day).
#
# Without this, the Liquidity score still computes from UUP+SPY-vol+BTC inputs,
# just without the RRPONTSYD (overnight reverse repo) contribution.
FRED_API_KEY=abcdef0123456789abcdef0123456789


# ---------- Runtime tunables (optional) ----------
# All have sensible defaults; set only to deviate.
# ROTATION_CONFIDENCE_FLOOR=0.35         # narratives below this confidence are suppressed (§4.4)
# ROTATION_BUCKET_FLAT_THRESHOLD=0.005   # |mean weekly return| below this = "flat" bucket in the flow map
# DEEPSEEK_TIMEOUT_S=45                  # LLM request timeout, seconds
# DEEPSEEK_MODEL=deepseek-chat           # LLM model id
# FRED_START_DATE=2024-11-01             # backfill start for FRED series
# (Note: config path / log level / db path are CLI+config.yaml concerns, not env vars.)


# ---------- Cloud-host hints (where this matters) ----------
# Heartbeat:        `rotate heartbeat`        runs once and reports.
# Daily pipeline:   `rotate daily`            fetches → signals → regime → report → alerts → heartbeat.
# Cron entry (UTC): `30 22 * * 1-5  cd /app && /app/.venv/bin/rotate daily`
#                   (22:30 UTC = ~30min after US equity close.)
